    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Login response has access token\", function () {",
                  "    let data = pm.response.json();",
                  "    pm.expect(data).to.have.property('access_token');",
                  "    pm.expect(data.access_token).to.be.a('string');",
                  "    pm.expect(data.access_token.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test(\"Login response has user data\", function () {",
                  "    let data = pm.response.json();",
                  "    pm.expect(data).to.have.property('access_token');",
                  "    pm.expect(data).to.have.property('refresh_token');",
                  "",
                  "});",
                  "",
                  "// Save token for protected endpoints",
                  "pm.test(\"Store access token for later use\", function () {",
                  "    let data = pm.response.json();",
                  "    pm.environment.set('access_token', data.access_token);",
                  "});",
                  "",
                  "let data = pm.response.json();",
                  "",
                  "// Save tokens to environment variables",
                  "pm.environment.set(\"access_token\", data.access_token);",
                  "pm.environment.set(\"refresh_token\", data.refresh_token);",
                  "",
                  "pm.test(\"Tokens exist\", function () {",
                  "    pm.expect(data).to.have.property(\"access_token\");",
                  "    pm.expect(data).to.have.property(\"refresh_token\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "\n{\n  \"email\": \"john@mail.com\",\n  \"password\": \"changeme\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseURL}}/auth/login",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
