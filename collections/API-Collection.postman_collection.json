        {
          "name": "Get All Products",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array with products\", function () {",
                  "    let data = pm.response.json();",
                  "    pm.expect(data).to.be.an('array');",
                  "    pm.expect(data.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "pm.test(\"Products have required fields\", function () {",
                  "    let products = pm.response.json();",
                  "    products.forEach(product => {",
                  "        pm.expect(product).to.have.property('id');",
                  "        pm.expect(product).to.have.property('title');",
                  "        pm.expect(product).to.have.property('price');",
                  "        pm.expect(product).to.have.property('description');",
                  "        pm.expect(product).to.have.property('images');",
                  "    });",
                  "});",
                  "",
                  "pm.test(\"Response time is under 2000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
